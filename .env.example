CITYBIKES_BASE_URL=https://api.citybik.es/v2
CITYBIKES_API_KEY=
CITYBIKES_NETWORK_CACHE_PATH=data/cache/resolved_networks.json
TARGET_CITIES=Paris,Lyon,Marseille,Toulouse,Bordeaux
POLL_INTERVAL_SECONDS=60

KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_TOPIC=bike-stations
KAFKA_CLIENT_ID=citybike-producer
KAFKA_REPLICATION_FACTOR=1
KAFKA_STARTING_OFFSETS=earliest

POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=citybike
POSTGRES_USER=citybike
POSTGRES_PASSWORD=citybike

SPARK_MASTER_URL=spark://spark-master:7077
SPARK_APP_NAME=citybike-stream-analytics
SPARK_CHECKPOINT_DIR=/opt/project/data/checkpoints/citybike_stream
PARQUET_OUTPUT_PATH=/opt/project/data/parquet/station_status

LOW_AVAILABILITY_THRESHOLD=2
CRITICAL_BIKES_THRESHOLD=2
CRITICAL_UTILIZATION_THRESHOLD=0.85
TOP_STATION_LIMIT=10
DASHBOARD_REFRESH_SECONDS=5
STREAMLIT_SERVER_PORT=8501
